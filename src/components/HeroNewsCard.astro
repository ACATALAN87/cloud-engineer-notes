---
/**
 * HeroNewsCard.astro
 *
 * Compact horizontal strip showing the latest Azure Blog post.
 * Positioned between hero and Core Skills as secondary content.
 * Silently renders nothing if required data is missing.
 */

interface Props {
  title:       string;
  url:         string;
  publishedAt: string;
  source:      string;
}

const { title, url, publishedAt, source } = Astro.props;

if (!title || !url) return;

const formattedDate = new Date(publishedAt).toLocaleDateString('en-US', {
  year:  'numeric',
  month: 'short',
  day:   'numeric',
});
---

<div class="border-b border-slate-800/60" style="background-color: #080d1a;">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="group flex flex-wrap items-center gap-x-4 gap-y-1.5 py-3 sm:flex-nowrap"
      aria-label={`Read on Azure Blog: ${title}`}
    >
      {/* Label */}
      <span
        class="flex-shrink-0 rounded border border-blue-900/60 px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-widest text-blue-400"
        style="background-color: rgba(30,58,138,0.15);"
      >
        {source}
      </span>

      {/* Separator — hidden on mobile */}
      <span class="hidden text-slate-700 sm:block" aria-hidden="true">·</span>

      {/* Title */}
      <span class="min-w-0 flex-1 truncate text-sm text-slate-400 group-hover:text-slate-200 transition-colors">
        {title}
      </span>

      {/* Date + icon */}
      <span class="flex flex-shrink-0 items-center gap-1.5 font-mono text-xs text-slate-600">
        <time datetime={publishedAt}>{formattedDate}</time>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 12 12"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-3 w-3 flex-shrink-0 transition-colors group-hover:text-slate-400"
          aria-hidden="true"
        >
          <path d="M2 10 10 2M5.5 2H10v4.5"/>
        </svg>
      </span>
    </a>
  </div>
</div>
