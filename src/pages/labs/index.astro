---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/react/ProjectCard';
import { getCollection } from 'astro:content';

const rawBase = import.meta.env.BASE_URL ?? '/';
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const labs = (await getCollection('labs', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const handsOn     = labs.filter((l) => l.data.labType === 'hands-on');
const architecture = labs.filter((l) => l.data.labType === 'architecture');
const devops      = labs.filter((l) => l.data.labType === 'devops');
const security    = labs.filter((l) => l.data.labType === 'security');
const uncategorised = labs.filter((l) => !l.data.labType);

const totalByType = [
  { label: 'Hands-on',     count: handsOn.length,     color: 'text-blue-400' },
  { label: 'Architecture', count: architecture.length, color: 'text-violet-400' },
  { label: 'DevOps',       count: devops.length,       color: 'text-cyan-400' },
  { label: 'Security',     count: security.length,     color: 'text-rose-400' },
].filter((t) => t.count > 0);
---

<BaseLayout
  title="Labs | Ángel Luis Catalán"
  description="Technical labs and hands-on projects on cloud engineering with Azure, Terraform and DevOps."
>
  <section class="border-b border-slate-800 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">

      <!-- Header -->
      <span class="text-xs font-semibold uppercase tracking-widest text-blue-400">Labs</span>
      <h1 class="mt-2 text-3xl font-bold text-white sm:text-4xl">Technical projects</h1>
      <p class="mt-3 max-w-2xl text-slate-400">
        Hands-on labs, real implementations and technical documentation on cloud infrastructure.
        Each lab includes code, decisions and lessons learned.
      </p>

      <!-- Type summary pills -->
      {totalByType.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {totalByType.map((t) => (
            <span class={`inline-flex items-center gap-1.5 rounded-full border border-slate-700/60 px-3 py-1 text-xs font-medium ${t.color}`} style="background-color: rgba(15,23,42,0.8);">
              {t.count} {t.label}
            </span>
          ))}
          <span class="inline-flex items-center gap-1.5 rounded-full border border-slate-700/60 px-3 py-1 text-xs font-medium text-slate-400" style="background-color: rgba(15,23,42,0.8);">
            {labs.length} total
          </span>
        </div>
      )}

      {labs.length > 0 ? (
        <div class="mt-12 space-y-14">

          <!-- Hands-on -->
          {handsOn.length > 0 && (
            <div>
              <div class="mb-5 flex items-center gap-3">
                <span class="font-mono text-[10px] font-bold uppercase tracking-widest text-blue-400">Hands-on</span>
                <div class="flex-1 border-t border-slate-800" aria-hidden="true"></div>
              </div>
              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {handsOn.map((lab) => (
                  <ProjectCard
                    title={lab.data.title}
                    description={lab.data.description}
                    stack={lab.data.stack}
                    href={`${base}labs/${lab.id.replace(/\.md$/, '')}/`}
                    date={lab.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
                    difficulty={lab.data.difficulty}
                    labType={lab.data.labType}
                  />
                ))}
              </div>
            </div>
          )}

          <!-- Architecture -->
          {architecture.length > 0 && (
            <div>
              <div class="mb-5 flex items-center gap-3">
                <span class="font-mono text-[10px] font-bold uppercase tracking-widest text-violet-400">Architecture</span>
                <div class="flex-1 border-t border-slate-800" aria-hidden="true"></div>
              </div>
              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {architecture.map((lab) => (
                  <ProjectCard
                    title={lab.data.title}
                    description={lab.data.description}
                    stack={lab.data.stack}
                    href={`${base}labs/${lab.id.replace(/\.md$/, '')}/`}
                    date={lab.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
                    difficulty={lab.data.difficulty}
                    labType={lab.data.labType}
                  />
                ))}
              </div>
            </div>
          )}

          <!-- DevOps -->
          {devops.length > 0 && (
            <div>
              <div class="mb-5 flex items-center gap-3">
                <span class="font-mono text-[10px] font-bold uppercase tracking-widest text-cyan-400">DevOps</span>
                <div class="flex-1 border-t border-slate-800" aria-hidden="true"></div>
              </div>
              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {devops.map((lab) => (
                  <ProjectCard
                    title={lab.data.title}
                    description={lab.data.description}
                    stack={lab.data.stack}
                    href={`${base}labs/${lab.id.replace(/\.md$/, '')}/`}
                    date={lab.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
                    difficulty={lab.data.difficulty}
                    labType={lab.data.labType}
                  />
                ))}
              </div>
            </div>
          )}

          <!-- Security -->
          {security.length > 0 && (
            <div>
              <div class="mb-5 flex items-center gap-3">
                <span class="font-mono text-[10px] font-bold uppercase tracking-widest text-rose-400">Security</span>
                <div class="flex-1 border-t border-slate-800" aria-hidden="true"></div>
              </div>
              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {security.map((lab) => (
                  <ProjectCard
                    title={lab.data.title}
                    description={lab.data.description}
                    stack={lab.data.stack}
                    href={`${base}labs/${lab.id.replace(/\.md$/, '')}/`}
                    date={lab.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
                    difficulty={lab.data.difficulty}
                    labType={lab.data.labType}
                  />
                ))}
              </div>
            </div>
          )}

          <!-- Uncategorised -->
          {uncategorised.length > 0 && (
            <div>
              <div class="mb-5 flex items-center gap-3">
                <span class="font-mono text-[10px] font-bold uppercase tracking-widest text-slate-500">Other</span>
                <div class="flex-1 border-t border-slate-800" aria-hidden="true"></div>
              </div>
              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {uncategorised.map((lab) => (
                  <ProjectCard
                    title={lab.data.title}
                    description={lab.data.description}
                    stack={lab.data.stack}
                    href={`${base}labs/${lab.id.replace(/\.md$/, '')}/`}
                    date={lab.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
                  />
                ))}
              </div>
            </div>
          )}

        </div>
      ) : (
        <p class="mt-12 text-sm text-slate-500">No labs published yet.</p>
      )}
    </div>
  </section>
</BaseLayout>
