---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const rawBase = import.meta.env.BASE_URL ?? '/';
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

export async function getStaticPaths() {
  const labs = await getCollection('labs', ({ data }) => !data.draft);
  return labs.map((lab) => ({
    params: { slug: lab.id.replace(/\.md$/, '') },
    props: { lab },
  }));
}

const { lab } = Astro.props;
const { Content } = await render(lab);

const DIFFICULTY_MAP: Record<string, { label: string; classes: string }> = {
  beginner:     { label: 'Beginner',     classes: 'border-emerald-800/60 text-emerald-400' },
  intermediate: { label: 'Intermediate', classes: 'border-amber-800/60 text-amber-400' },
  advanced:     { label: 'Advanced',     classes: 'border-red-800/60 text-red-400' },
};

const LAB_TYPE_MAP: Record<string, { label: string; classes: string }> = {
  'hands-on':    { label: 'Hands-on',    classes: 'border-blue-800/60 text-blue-300' },
  'architecture':{ label: 'Architecture',classes: 'border-violet-800/60 text-violet-300' },
  'devops':      { label: 'DevOps',      classes: 'border-cyan-800/60 text-cyan-300' },
  'security':    { label: 'Security',    classes: 'border-rose-800/60 text-rose-300' },
};

const diff    = lab.data.difficulty ? DIFFICULTY_MAP[lab.data.difficulty] : null;
const labtype = lab.data.labType    ? LAB_TYPE_MAP[lab.data.labType]      : null;
---

<BaseLayout title={lab.data.title} description={lab.data.description}>
  <article class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-20">

    <!-- Back -->
    <a
      href={`${base}labs/`}
      class="mb-8 inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-300 transition-colors"
    >
      ← Back to Labs
    </a>

    <!-- Header -->
    <header class="mb-10 border-b border-slate-800 pb-8">
      <div class="mb-4 flex flex-wrap items-center gap-2">
        <p class="font-mono text-xs text-slate-500">
          {lab.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
        {labtype && (
          <span
            class={`rounded border px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-wider ${labtype.classes}`}
            style="background-color: rgba(15,23,42,0.7);"
          >
            {labtype.label}
          </span>
        )}
        {diff && (
          <span
            class={`rounded border px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-wider ${diff.classes}`}
            style="background-color: rgba(15,23,42,0.7);"
          >
            {diff.label}
          </span>
        )}
      </div>

      <h1 class="text-2xl font-bold text-white sm:text-3xl leading-tight">
        {lab.data.title}
      </h1>
      <p class="mt-3 text-slate-400 leading-relaxed">{lab.data.description}</p>

      {lab.data.stack && lab.data.stack.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {lab.data.stack.map((tech: string) => (
            <span
              class="rounded border border-slate-700 px-2.5 py-0.5 font-mono text-xs text-slate-400"
              style="background-color: rgba(51,65,85,0.3);"
            >
              {tech}
            </span>
          ))}
        </div>
      )}

      {lab.data.source && (
        <div class="mt-5">
          <a
            href={lab.data.source}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs text-slate-500 hover:text-blue-400 transition-colors"
          >
            <svg class="h-3 w-3" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 3H3a1 1 0 0 0-1 1v9a1 1 0 0 0 1 1h9a1 1 0 0 0 1-1v-3M9 2h5m0 0v5m0-5L7 10"/>
            </svg>
            Reference: {lab.data.sourceName ?? lab.data.source}
          </a>
        </div>
      )}
    </header>

    <!-- Cover image -->
    {lab.data.cover && (
      <div class="mb-10">
        <img
          src={`${base}${lab.data.cover.replace(/^\/+/, '')}`}
          alt={lab.data.title}
          class="w-full rounded-lg border border-slate-800"
        />
      </div>
    )}

    <!-- Content -->
    <div class="prose prose-invert prose-slate max-w-none
                prose-headings:font-semibold prose-headings:tracking-tight prose-headings:text-white
                prose-h2:mt-10 prose-h2:mb-4 prose-h2:text-xl
                prose-h3:mt-6 prose-h3:mb-3 prose-h3:text-lg
                prose-p:text-slate-400 prose-p:leading-7
                prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline
                prose-strong:text-slate-200 prose-strong:font-semibold
                prose-code:text-slate-300 prose-code:font-mono prose-code:text-sm
                prose-pre:border prose-pre:border-slate-700/80
                prose-li:text-slate-400
                prose-hr:border-slate-800
                prose-blockquote:border-l-blue-600 prose-blockquote:text-slate-400">
      <Content />
    </div>

    <!-- Footer nav -->
    <div class="mt-16 border-t border-slate-800 pt-8">
      <a
        href={`${base}labs/`}
        class="text-sm text-slate-400 hover:text-white transition-colors"
      >
        ← Back to Labs
      </a>
    </div>
  </article>
</BaseLayout>

