---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceTimeline from '../components/react/ExperienceTimeline';
import CertificationsGrid from '../components/react/CertificationsGrid';
import CTASection from '../components/react/CTASection';
---

<BaseLayout
  title="About | Ángel Luis Catalán"
  description="Perfil profesional — Senior Cloud Engineer especializado en Azure, Terraform y platform engineering."
>
  <!-- Profile header -->
  <section class="border-b border-slate-800 py-20" style="background-color: #0a0f1e;">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <span class="text-xs font-semibold uppercase tracking-widest text-blue-400">
        About
      </span>
      <h1 class="mt-3 text-3xl font-bold text-white sm:text-4xl">
        Ángel Luis Catalán
      </h1>
      <p class="mt-2 text-lg font-medium text-slate-300">
        Senior Cloud Engineer (Azure) · Terraform · DevOps · Enterprise Infrastructure
      </p>
      <p class="mt-1 text-sm text-slate-500">📍 Madrid, España</p>

      <p class="mt-6 max-w-2xl text-base leading-7 text-slate-400">
        Senior Cloud Engineer con más de 10 años de experiencia en entornos enterprise,
        especializado en infraestructura Azure, automatización y platform engineering.
        Experiencia en sistemas críticos 24x7, Infrastructure as Code con Terraform,
        networking en Azure, DevOps e integración de plataformas cloud. Enfocado en
        construir soluciones escalables, seguras y resilientes, evolucionando hacia
        roles de Cloud Architecture.
      </p>

      <div class="mt-6 flex flex-wrap gap-2">
        <span class="rounded-md border border-slate-700 bg-slate-800/50 px-3 py-1 text-sm text-slate-300">
          10+ años de experiencia
        </span>
        <span class="rounded-md border border-slate-700 bg-slate-800/50 px-3 py-1 text-sm text-slate-300">
          Enterprise
        </span>
        <span class="rounded-md border border-blue-800 px-3 py-1 text-sm text-blue-300" style="background-color: rgba(30,58,138,0.15);">
          Azure Specialist
        </span>
        <span class="rounded-md border border-violet-800 px-3 py-1 text-sm text-violet-300" style="background-color: rgba(76,29,149,0.15);">
          Terraform
        </span>
      </div>
    </div>
  </section>

  <!-- Focus areas -->
  <section class="border-b border-slate-800 py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <span class="text-xs font-semibold uppercase tracking-widest text-blue-400">
        Especialización
      </span>
      <h2 class="mt-2 text-2xl font-bold text-white sm:text-3xl">
        Áreas de especialización
      </h2>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            area: 'Cloud Infrastructure',
            desc: 'Diseño y despliegue de infraestructura Azure escalable, segura y de alto rendimiento en entornos enterprise.',
          },
          {
            area: 'Infrastructure as Code',
            desc: 'Automatización completa con Terraform: módulos reutilizables, gestión de estado remoto y pipelines IaC.',
          },
          {
            area: 'DevOps & CI/CD',
            desc: 'Pipelines en Azure DevOps y GitHub Actions. Integración y entrega continua para workloads enterprise.',
          },
          {
            area: 'Platform Engineering',
            desc: 'Construcción y mantenimiento de plataformas internas para habilitar equipos de desarrollo a escala.',
          },
          {
            area: 'Networking & Security',
            desc: 'Arquitectura de red en Azure: NSG, firewall, VPN, peering, ExpressRoute y troubleshooting avanzado.',
          },
          {
            area: 'Workload Automation',
            desc: 'Más de 10 años gestionando plataformas de automatización enterprise en entornos críticos 24x7.',
          },
        ].map(({ area, desc }) => (
          <div class="rounded-lg border border-slate-800 p-5" style="background-color: #0f172a;">
            <h3 class="text-sm font-semibold text-white">{area}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-400">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stack principal -->
  <section class="border-b border-slate-800 py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <span class="text-xs font-semibold uppercase tracking-widest text-blue-400">
        Stack
      </span>
      <h2 class="mt-2 text-2xl font-bold text-white sm:text-3xl">
        Stack principal
      </h2>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { category: 'Cloud',           items: ['Microsoft Azure', 'Azure Virtual Machines', 'Azure Networking', 'Azure DevOps'] },
          { category: 'IaC & Automation',items: ['Terraform', 'GitHub Actions', 'CI/CD Pipelines', 'Azure Pipelines'] },
          { category: 'Datos',           items: ['Snowflake', 'Couchbase Capella', 'Azure Data Factory', 'SQL Server'] },
          { category: 'Infra & OS',      items: ['Linux', 'Windows Server', 'Bash / Shell', 'Git'] },
        ].map(({ category, items }) => (
          <div class="rounded-lg border border-slate-800 p-4" style="background-color: #0f172a;">
            <h3 class="mb-3 text-xs font-semibold uppercase tracking-widest text-slate-500">{category}</h3>
            <ul class="space-y-1.5">
              {items.map((item) => (
                <li class="text-sm text-slate-300">{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ExperienceTimeline />

  <CertificationsGrid />

  <CTASection />
</BaseLayout>
