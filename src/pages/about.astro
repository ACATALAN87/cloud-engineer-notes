---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceTimeline from '../components/react/ExperienceTimeline';
import CertificationsGrid from '../components/react/CertificationsGrid';
import CTASection from '../components/react/CTASection';
---

<BaseLayout
  title="About | Ángel Luis Catalán"
  description="Senior Cloud Engineer specialised in Azure, Terraform and platform engineering. Professional profile and background."
>
  <!-- Profile header -->
  <section class="border-b border-slate-800 py-24" style="background-color: #0a0f1e;">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <span class="font-mono text-xs font-semibold uppercase tracking-widest text-blue-400">
        About
      </span>
      <h1 class="mt-3 text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
        Ángel Luis Catalán
      </h1>
      <p class="mt-3 text-lg font-medium text-slate-300">
        Senior Cloud Engineer · Azure · Terraform · DevOps
      </p>
      <p class="mt-1 font-mono text-sm text-slate-500">Madrid, Spain</p>

      <p class="mt-7 max-w-2xl text-base leading-8 text-slate-400">
        Cloud engineer with a strong foundation in real-world operations, automation, platform
        engineering and enterprise infrastructure. More than 10 years working in critical
        environments across multinational companies — from workload automation to full cloud
        platform design and delivery on Azure.
      </p>
      <p class="mt-4 max-w-2xl text-base leading-8 text-slate-400">
        Currently focused on Azure infrastructure design, Infrastructure as Code with Terraform,
        DevOps practices and platform engineering. Evolving towards cloud architecture and
        enterprise platform design roles.
      </p>

      <div class="mt-8 flex flex-wrap gap-2">
        <span class="rounded-md border border-blue-800/70 px-3 py-1 text-sm text-blue-300" style="background-color: rgba(30,58,138,0.15);">
          Azure
        </span>
        <span class="rounded-md border border-violet-800/70 px-3 py-1 text-sm text-violet-300" style="background-color: rgba(76,29,149,0.15);">
          Terraform
        </span>
        <span class="rounded-md border border-slate-700 px-3 py-1 text-sm text-slate-300" style="background-color: rgba(51,65,85,0.3);">
          Platform Engineering
        </span>
        <span class="rounded-md border border-slate-700 px-3 py-1 text-sm text-slate-300" style="background-color: rgba(51,65,85,0.3);">
          10+ years enterprise
        </span>
      </div>
    </div>
  </section>

  <!-- How I approach infrastructure -->
  <section class="border-b border-slate-800 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <span class="font-mono text-xs font-semibold uppercase tracking-widest text-blue-400">
        Approach
      </span>
      <h2 class="mt-2 text-2xl font-bold text-white sm:text-3xl">
        How I think about infrastructure
      </h2>

      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            title: 'Infrastructure is a product',
            desc:  'Cloud infrastructure should be designed like a product: versioned, tested, documented and maintained. Not scripted once and forgotten.',
          },
          {
            title: 'Automation over manual work',
            desc:  'If something needs to be done more than once, it should be automated. Terraform, GitHub Actions and Azure DevOps pipelines are first-class tools, not shortcuts.',
          },
          {
            title: 'Security by design',
            desc:  'RBAC, network segmentation, least privilege and governance policies are not add-ons — they are part of the design from the start.',
          },
          {
            title: 'Operational discipline',
            desc:  'Years in 24x7 critical environments build habits: runbooks, clear documentation, structured incident response and no surprises in production.',
          },
          {
            title: 'Platform thinking',
            desc:  'Infrastructure should enable teams, not slow them down. Platform engineering means building internal capabilities that scale across projects and people.',
          },
          {
            title: 'Evolving towards architecture',
            desc:  'Combining hands-on engineering experience with a growing focus on cloud design patterns, networking architecture and enterprise-scale Azure solutions.',
          },
        ].map(({ title, desc }) => (
          <div class="rounded-xl border border-slate-800 p-6" style="background-color: #0d1424;">
            <h3 class="text-sm font-semibold text-white">{title}</h3>
            <p class="mt-2.5 text-sm leading-relaxed text-slate-400">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stack -->
  <section class="border-b border-slate-800 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <span class="font-mono text-xs font-semibold uppercase tracking-widest text-blue-400">
        Stack
      </span>
      <h2 class="mt-2 text-2xl font-bold text-white sm:text-3xl">
        Core technical stack
      </h2>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {[
          {
            category: 'Cloud & Networking',
            accent:   'text-blue-400',
            items:    ['Microsoft Azure', 'Azure Virtual Networks', 'NSGs & Firewalls', 'VPN Gateway / ExpressRoute', 'Azure DNS', 'Azure Monitor'],
          },
          {
            category: 'IaC & DevOps',
            accent:   'text-violet-400',
            items:    ['Terraform', 'Azure DevOps', 'GitHub Actions', 'Azure Pipelines', 'CI/CD', 'Git'],
          },
          {
            category: 'Data & Platforms',
            accent:   'text-cyan-400',
            items:    ['Azure Data Factory', 'Snowflake', 'Couchbase Capella', 'SQL Server', 'Appian', 'RBAC'],
          },
          {
            category: 'Infra & OS',
            accent:   'text-slate-400',
            items:    ['Linux (RHEL / Ubuntu)', 'Windows Server', 'Bash / Shell', 'IBM InfoSphere', 'Control-M', 'TWS / Workload Scheduler'],
          },
        ].map(({ category, accent, items }) => (
          <div class="rounded-xl border border-slate-800 p-5" style="background-color: #0d1424;">
            <h3 class={`mb-4 text-xs font-bold uppercase tracking-widest ${accent}`}>{category}</h3>
            <ul class="space-y-2">
              {items.map((item) => (
                <li class="text-sm text-slate-300">{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ExperienceTimeline />

  <CertificationsGrid />

  <CTASection />
</BaseLayout>
