---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const labs = (await getCollection("labs", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);
---

<BaseLayout
  title="Ángel | Cloud Engineer"
  description="Notas prácticas sobre cloud, Azure y automatización."
>
  <section class="hero hero-modern">
    <div class="hero-copy">
      <div class="hero-badge">Infraestructura · CI/CD · Terraform</div>

      <h1 class="hero-title">
        Construyendo soluciones cloud
        <span>con enfoque práctico</span>
      </h1>

      <p class="hero-text">
        Notas reales sobre Azure, Terraform y arquitectura cloud.
        Sin teoría innecesaria, centrado en ejecución.
      </p>

      <div class="hero-actions">
        <a class="hero-btn hero-btn-primary" href={`${base}blog/`}>Ver artículos</a>
        <a class="hero-btn hero-btn-secondary" href={`${base}labs/`}>Ver labs</a>
      </div>
    </div>

    <div class="hero-panel">
      <div class="window-card">
        <div class="window-topbar">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="window-content">
          <p class="window-kicker">Lab reciente</p>
          <h3>Web técnica con Astro</h3>
          <p>
            Deploy automático, contenido en Markdown y estructura escalable.
          </p>

          <div class="window-tags">
            <span>Astro</span>
            <span>CI/CD</span>
            <span>GitHub</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <h2>Últimos artículos</h2>
    <div class="grid grid-3">
      {posts.map((post) => (
        <article class="card">
          <p class="muted">{post.data.date.toLocaleDateString("es-ES")}</p>
          <h3>
            <a href={`${base}blog/${post.id.replace(/\.md$/, "")}/`}>{post.data.title}</a>
          </h3>
          <p class="muted">{post.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <h2>Labs recientes</h2>
    <div class="grid grid-2">
      {labs.map((lab) => (
        <article class="card">
          <p class="muted">{lab.data.date.toLocaleDateString("es-ES")}</p>
          <h3>
            <a href={`${base}labs/${lab.id.replace(/\.md$/, "")}/`}>{lab.data.title}</a>
          </h3>
          <p class="muted">{lab.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <h2>Qué encontrarás aquí</h2>
    <div class="grid grid-3">
      <article class="card">
        <h3>Blog técnico</h3>
        <p class="muted">
          Artículos sobre Azure, Terraform, AKS, observabilidad, identidad e infraestructura.
        </p>
      </article>

      <article class="card">
        <h3>Labs reproducibles</h3>
        <p class="muted">
          Proyectos reales con foco en ejecución, arquitectura y decisiones técnicas.
        </p>
      </article>

      <article class="card">
        <h3>Briefings cloud</h3>
        <p class="muted">
          Resúmenes de novedades con foco en impacto operativo y criterio de ingeniería.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>