---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/react/Hero';
import SkillGrid from '../components/react/SkillGrid';
import ExperienceTimeline from '../components/react/ExperienceTimeline';
import CertificationsGrid from '../components/react/CertificationsGrid';
import CTASection from '../components/react/CTASection';
import ProjectCard from '../components/react/ProjectCard';
import ArticleCard from '../components/react/ArticleCard';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const labs = (await getCollection('labs', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Ángel Luis Catalán | Senior Cloud Engineer"
  description="Senior Cloud Engineer especializado en Azure, Terraform, DevOps e infraestructura enterprise. Madrid, España."
>
  <Hero base={base} />

  <SkillGrid />

  <ExperienceTimeline />

  <CertificationsGrid />

  <!-- Featured Labs -->
  <section class="border-b border-slate-800 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 flex items-end justify-between gap-4">
        <div>
          <span class="text-xs font-semibold uppercase tracking-widest text-blue-400">
            Labs
          </span>
          <h2 class="mt-2 text-2xl font-bold text-white sm:text-3xl">
            Proyectos técnicos
          </h2>
        </div>
        <a
          href={`${base}labs/`}
          class="whitespace-nowrap text-sm text-slate-400 hover:text-white transition-colors"
        >
          Ver todos →
        </a>
      </div>

      {labs.length > 0 ? (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {labs.map((lab) => (
            <ProjectCard
              title={lab.data.title}
              description={lab.data.description}
              stack={lab.data.stack}
              href={`${base}labs/${lab.id.replace(/\.md$/, '')}/`}
              date={lab.data.date.toLocaleDateString('es-ES')}
            />
          ))}
        </div>
      ) : (
        <p class="text-sm text-slate-500">No hay labs publicados todavía.</p>
      )}
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="border-b border-slate-800 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 flex items-end justify-between gap-4">
        <div>
          <span class="text-xs font-semibold uppercase tracking-widest text-blue-400">
            Blog
          </span>
          <h2 class="mt-2 text-2xl font-bold text-white sm:text-3xl">
            Últimos artículos
          </h2>
        </div>
        <a
          href={`${base}blog/`}
          class="whitespace-nowrap text-sm text-slate-400 hover:text-white transition-colors"
        >
          Ver todos →
        </a>
      </div>

      {posts.length > 0 ? (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              href={`${base}blog/${post.id.replace(/\.md$/, '')}/`}
              date={post.data.date.toLocaleDateString('es-ES')}
              tags={post.data.tags}
            />
          ))}
        </div>
      ) : (
        <p class="text-sm text-slate-500">No hay artículos publicados todavía.</p>
      )}
    </div>
  </section>

  <CTASection />
</BaseLayout>
