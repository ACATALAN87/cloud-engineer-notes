---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/react/ArticleCard';
import { getCollection } from 'astro:content';

const rawBase = import.meta.env.BASE_URL ?? '/';
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Blog | Ángel Luis Catalán"
  description="Technical notes on Azure, Terraform, DevOps and cloud infrastructure."
>
  <section class="border-b border-slate-800 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <span class="text-xs font-semibold uppercase tracking-widest text-blue-400">
        Blog
      </span>
      <h1 class="mt-2 text-3xl font-bold text-white sm:text-4xl">
        Technical notes
      </h1>
      <p class="mt-3 max-w-2xl text-slate-400">
        Articles, deep dives and field notes on cloud engineering, infrastructure and DevOps.
      </p>

      {posts.length > 0 ? (
        <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <div class="relative">
              {post.data.category === 'Azure News' && (
                <span class="absolute right-3 top-3 z-10 inline-flex items-center gap-1 rounded px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-widest text-blue-400/80 ring-1 ring-blue-800/50" style="background-color: rgba(30,58,138,0.15);">
                  Azure News
                </span>
              )}
              <ArticleCard
                title={post.data.title}
                description={post.data.description}
                href={`${base}blog/${post.id.replace(/\.md$/, '')}/`}
                date={post.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}
                tags={post.data.tags}
              />
            </div>
          ))}
        </div>
      ) : (
        <p class="mt-12 text-sm text-slate-500">No articles published yet.</p>
      )}
    </div>
  </section>
</BaseLayout>
