---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/react/ArticleCard';
import { getCollection } from 'astro:content';

const rawBase = import.meta.env.BASE_URL ?? '/';
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Blog | Ángel Luis Catalán"
  description="Artículos técnicos sobre Azure, Terraform, DevOps e infraestructura cloud."
>
  <section class="border-b border-slate-800 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <span class="text-xs font-semibold uppercase tracking-widest text-blue-400">
        Blog
      </span>
      <h1 class="mt-2 text-3xl font-bold text-white sm:text-4xl">
        Notas técnicas
      </h1>
      <p class="mt-3 max-w-2xl text-slate-400">
        Artículos, apuntes y reflexiones sobre cloud engineering, infraestructura y DevOps.
      </p>

      {posts.length > 0 ? (
        <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              href={`${base}blog/${post.id.replace(/\.md$/, '')}/`}
              date={post.data.date.toLocaleDateString('es-ES')}
              tags={post.data.tags}
            />
          ))}
        </div>
      ) : (
        <p class="mt-12 text-sm text-slate-500">No hay artículos publicados todavía.</p>
      )}
    </div>
  </section>
</BaseLayout>
