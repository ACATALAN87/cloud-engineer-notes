---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="Blog | Ángel" description="Artículos técnicos sobre cloud y Azure.">
  <section>
    <h1>Blog</h1>
    <p class="muted">Artículos técnicos escritos en Markdown.</p>

    <div class="grid">
      {posts.map((post) => (
        <article class="card">
          <h3>
           <a href={`${base}blog/${post.id.replace(/\.md$/, "")}/`}>{post.data.title}</a>
          </h3>
          <p class="muted">{post.data.description}</p>
          <p class="muted">
            {post.data.date.toLocaleDateString("es-ES")}
          </p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
