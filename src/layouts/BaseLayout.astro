---
const { title = "Ángel | Cloud Engineer", description = "Cloud Engineer centrado en Azure, automatización e infraestructura práctica." } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root {
        --bg: #020617;
        --panel: #0f172a;
        --panel-soft: #111827;
        --border: #1e293b;
        --text: #e2e8f0;
        --muted: #94a3b8;
        --accent: #22d3ee;
        --accent-soft: rgba(34, 211, 238, 0.12);
        --max: 1100px;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        width: min(var(--max), calc(100% - 2rem));
        margin: 0 auto;
      }

      header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(10px);
        background: rgba(2, 6, 23, 0.88);
        border-bottom: 1px solid var(--border);
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 0;
        gap: 1rem;
      }

      .brand {
        display: flex;
        flex-direction: column;
      }

      .brand strong {
        font-size: 1.05rem;
      }

      .brand span {
        color: var(--muted);
        font-size: 0.9rem;
      }

      nav ul {
        list-style: none;
        display: flex;
        gap: 1.2rem;
        padding: 0;
        margin: 0;
        flex-wrap: wrap;
      }

      nav a {
        color: var(--muted);
      }

      nav a:hover {
        color: white;
      }

      main {
        padding: 3rem 0 4rem;
      }

      .hero {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 2rem;
        padding: 2rem 0 4rem;
      }

      .badge {
        display: inline-block;
        padding: 0.35rem 0.8rem;
        border: 1px solid rgba(34, 211, 238, 0.25);
        background: var(--accent-soft);
        color: #a5f3fc;
        border-radius: 999px;
        font-size: 0.8rem;
        margin-bottom: 1rem;
      }

      h1, h2, h3 {
        line-height: 1.15;
        margin-top: 0;
      }

      h1 {
        font-size: clamp(2.4rem, 5vw, 4.4rem);
        margin-bottom: 1rem;
      }

      .lead {
        font-size: 1.1rem;
        color: var(--text);
        max-width: 48rem;
      }

      .muted {
        color: var(--muted);
      }

      .button-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
      }

      .btn {
        display: inline-block;
        padding: 0.9rem 1.2rem;
        border-radius: 16px;
        border: 1px solid var(--border);
      }

      .btn-primary {
        background: white;
        color: #020617;
        border-color: white;
        font-weight: 600;
      }

      .btn-secondary {
        background: transparent;
        color: var(--text);
      }

      .card {
        background: rgba(15, 23, 42, 0.75);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 1.25rem;
      }

      .grid {
        display: grid;
        gap: 1.25rem;
      }

      .grid-3 {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .grid-2 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      section {
        margin-top: 3rem;
      }

      footer {
        border-top: 1px solid var(--border);
        padding: 2rem 0 4rem;
        color: var(--muted);
      }

      @media (max-width: 900px) {
        .hero,
        .grid-3,
        .grid-2 {
          grid-template-columns: 1fr;
        }

        .nav {
          align-items: flex-start;
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container nav">
        <div class="brand">
          <strong>Ángel | Cloud Engineer</strong>
          <span>Azure · Automatización · Arquitectura práctica</span>
        </div>

        <nav>
          <ul>
            <li><a href="/">Inicio</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/labs">Labs</a></li>
            <li><a href="/about">Sobre mí</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer>
      <div class="container">
        <p>Web personal técnica de Ángel. Construida con Astro, Markdown y despliegue estático.</p>
      </div>
    </footer>
  </body>
</html>
