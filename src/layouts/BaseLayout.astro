---
const {
  title = "Ángel Luis| Cloud Engineer",
  description = "Cloud Engineer centrado en Azure, automatización e infraestructura práctica."
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style is:global>
      :root {
        --bg: #020617;
        --panel: #0f172a;
        --panel-soft: #111827;
        --border: #1e293b;
        --text: #e2e8f0;
        --muted: #94a3b8;
        --accent: #22d3ee;
        --accent-soft: rgba(34, 211, 238, 0.12);
        --max: 1100px;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        width: min(var(--max), calc(100% - 2rem));
        margin: 0 auto;
      }

      header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(10px);
        background: rgba(2, 6, 23, 0.88);
        border-bottom: 1px solid var(--border);
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 0;
        gap: 1rem;
      }

      .brand {
        display: flex;
        flex-direction: column;
      }

      .brand strong {
        font-size: 1.05rem;
      }

      .brand span {
        color: var(--muted);
        font-size: 0.9rem;
      }

      nav ul {
        list-style: none;
        display: flex;
        gap: 1.2rem;
        padding: 0;
        margin: 0;
        flex-wrap: wrap;
      }

      nav a {
        color: var(--muted);
      }

      nav a:hover {
        color: white;
      }

      main {
        padding: 1rem 0 4rem;
        }

      .hero {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 2rem;
        padding: 2rem 0 4rem;
      }

      .badge {
        display: inline-block;
        padding: 0.35rem 0.8rem;
        border: 1px solid rgba(34, 211, 238, 0.25);
        background: var(--accent-soft);
        color: #a5f3fc;
        border-radius: 999px;
        font-size: 0.8rem;
        margin-bottom: 1rem;
      }

      h1, h2, h3 {
        line-height: 1.15;
        margin-top: 0;
      }

      h1 {
        font-size: clamp(2.4rem, 5vw, 4.4rem);
        margin-bottom: 1rem;
      }

      .lead {
        font-size: 1.1rem;
        color: var(--text);
        max-width: 48rem;
      }

      .muted {
        color: var(--muted);
      }

      .button-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
      }

      .btn {
        display: inline-block;
        padding: 0.9rem 1.2rem;
        border-radius: 16px;
        border: 1px solid var(--border);
      }

      .btn-primary {
        background: white;
        color: #020617;
        border-color: white;
        font-weight: 600;
      }

      .btn-secondary {
        background: transparent;
        color: var(--text);
      }

      .card {
        background: rgba(15, 23, 42, 0.75);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 1.25rem;
      }

      .grid {
        display: grid;
        gap: 1.25rem;
      }

      .grid-3 {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .grid-2 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      section {
        margin-top: 3rem;
      }

      footer {
        border-top: 1px solid var(--border);
        padding: 2rem 0 4rem;
        color: var(--muted);
      }

      /* ===== Mejoras para contenido de artículos ===== */

      article.card {
        max-width: 860px;
      }

      article.card h1 {
        margin-bottom: 0.75rem;
      }

      article.card h2 {
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        font-size: 2rem;
      }

      article.card h3 {
        margin-top: 1.75rem;
        margin-bottom: 0.75rem;
        font-size: 1.3rem;
      }

      article.card p {
        margin: 1rem 0;
        color: var(--text);
      }

      article.card ul,
      article.card ol {
        margin: 1rem 0 1rem 1.5rem;
      }

      article.card li {
        margin: 0.5rem 0;
      }

      article.card code {
        background: rgba(148, 163, 184, 0.12);
        padding: 0.15rem 0.4rem;
        border-radius: 6px;
        font-size: 0.95em;
      }

      article.card pre {
        background: #1f2937;
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1rem;
        overflow-x: auto;
        margin: 1.25rem 0;
      }

      article.card pre code {
        background: transparent;
        padding: 0;
      }

      /* ===== HOME MODERNA ===== */

      .hero-modern {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 3rem;
        align-items: center;
        margin: 1rem 0 4rem;
      }

      .hero-copy {
        max-width: 720px;
      }

      .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.45rem 0.9rem;
        border-radius: 999px;
        background: rgba(34, 211, 238, 0.1);
        border: 1px solid rgba(34, 211, 238, 0.22);
        color: #a5f3fc;
        font-size: 0.85rem;
        margin-bottom: 1.2rem;
      }

      .hero-title {
        font-size: clamp(2.8rem, 6vw, 4.8rem);
        line-height: 1.05;
        letter-spacing: -0.03em;
        margin-bottom: 1rem;
      }

      .hero-title span {
        display: block;
        background: linear-gradient(90deg, #7dd3fc, #a78bfa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .hero-text {
        font-size: 1.18rem;
        line-height: 1.8;
        color: var(--muted);
        max-width: 60ch;
      }

      .hero-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 2rem;
      }

      .hero-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.95rem 1.25rem;
        border-radius: 16px;
        font-weight: 600;
        transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
      }

      .hero-btn:hover {
        transform: translateY(-2px);
      }

      .hero-btn-primary {
        background: white;
        color: #020617;
        border: 1px solid white;
      }

      .hero-btn-secondary {
        background: rgba(15, 23, 42, 0.8);
        color: var(--text);
        border: 1px solid var(--border);
      }

      .hero-panel {
        display: flex;
        justify-content: center;
      }

      .window-card {
        width: 100%;
        max-width: 420px;
        border-radius: 24px;
        border: 1px solid rgba(148, 163, 184, 0.18);
        background: linear-gradient(180deg, rgba(15, 23, 42, 0.98), rgba(2, 6, 23, 0.98));
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
        overflow: hidden;
      }

      .window-topbar {
        display: flex;
        gap: 0.45rem;
        padding: 0.9rem 1rem;
        border-bottom: 1px solid rgba(148, 163, 184, 0.12);
        background: rgba(2, 6, 23, 0.8);
      }

      .window-topbar span {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        display: inline-block;
      }

      .window-topbar span:nth-child(1) { background: #ef4444; }
      .window-topbar span:nth-child(2) { background: #f59e0b; }
      .window-topbar span:nth-child(3) { background: #22c55e; }

      .window-content {
        padding: 1.5rem;
      }

      .window-kicker {
        color: #7dd3fc;
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.75rem;
      }

      .window-content h3 {
        margin: 0 0 0.75rem;
        font-size: 1.65rem;
      }

      .window-content p {
        color: var(--muted);
        line-height: 1.7;
      }

      .window-tags {
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
        margin-top: 1.25rem;
      }

      .window-tags span {
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        background: rgba(148, 163, 184, 0.12);
        border: 1px solid rgba(148, 163, 184, 0.14);
        font-size: 0.82rem;
        color: #cbd5e1;
      }

      .card {
        transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
      }

      .card:hover {
        transform: translateY(-4px);
        border-color: rgba(96, 165, 250, 0.35);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.18);
      }

      @media (max-width: 900px) {
        .hero,
        .grid-3,
        .grid-2,
        .hero-modern {
          grid-template-columns: 1fr;
        }

        .nav {
          align-items: flex-start;
          flex-direction: column;
        }

        .hero-title span {
          display: inline;
        }

        .hero-panel {
          justify-content: stretch;
        }

        .window-card {
          max-width: none;
        }
      }
      /* ===== ABOUT ===== */

.about {
  max-width: 900px;
}

.about-hero {
  margin-bottom: 3rem;
}

.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
}

.about-block ul {
  margin-top: 1rem;
}

.about-stack {
  margin-top: 4rem;
}

.stack-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
}

.stack-card {
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 1rem;
  background: rgba(15, 23, 42, 0.6);
}

.about-project {
  margin-top: 4rem;
}

.about-links {
  display: flex;
  gap: 1rem;
  margin-top: 1.5rem;
}

/* responsive */

@media (max-width: 900px) {
  .about-grid {
    grid-template-columns: 1fr;
  }

  .stack-grid {
    grid-template-columns: 1fr 1fr;
  }
}

/* ===== FOOTER PREMIUM ===== */

.site-footer {
  margin-top: 6rem;
  padding: 0 0 2rem;
}

.footer-shell {
  border-top: 1px solid rgba(148, 163, 184, 0.12);
  padding-top: 2.5rem;
}

.footer-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr;
  gap: 2.5rem;
  align-items: start;
}

.footer-brand-top {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.8rem;
}

.footer-brand-top h3 {
  margin: 0;
  font-size: 1.05rem;
}

.footer-dot {
  width: 10px;
  height: 10px;
  border-radius: 999px;
  background: linear-gradient(90deg, #7dd3fc, #a78bfa);
  box-shadow: 0 0 18px rgba(125, 211, 252, 0.55);
}

.footer-description {
  max-width: 42ch;
  line-height: 1.8;
  margin-bottom: 1rem;
}

.footer-stack-pill {
  display: inline-flex;
  align-items: center;
  padding: 0.5rem 0.85rem;
  border-radius: 999px;
  font-size: 0.82rem;
  color: #cbd5e1;
  border: 1px solid rgba(148, 163, 184, 0.14);
  background: rgba(15, 23, 42, 0.7);
}

.footer-title {
  margin: 0 0 0.9rem;
  font-size: 0.9rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: #cbd5e1;
}

.footer-links {
  list-style: none;
  padding: 0;
  margin: 0;
}

.footer-links li {
  margin: 0.7rem 0;
}

.footer-links a {
  color: var(--muted);
  transition: color 0.2s ease, transform 0.2s ease;
}

.footer-links a:hover {
  color: white;
}

.footer-bottom {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
  margin-top: 2.5rem;
  padding-top: 1.25rem;
  border-top: 1px solid rgba(148, 163, 184, 0.08);
}

@media (max-width: 900px) {
  .footer-grid {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .footer-bottom {
    flex-direction: column;
  }
}
    </style>
  </head>
  <body>
    <header>
      <div class="container nav">
        <div class="brand">
          <strong>Ángel | Cloud Engineer</strong>
          <span>Azure · Automatización · Arquitectura práctica</span>
        </div>

        <nav>
          <ul>
            <li><a href={base}>Inicio</a></li>
            <li><a href={`${base}blog/`}>Blog</a></li>
            <li><a href={`${base}labs/`}>Labs</a></li>
            <li><a href={`${base}about/`}>Sobre mí</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

<footer class="site-footer">
  <div class="container footer-shell">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-brand-top">
          <span class="footer-dot"></span>
          <h3>Ángel | Cloud Engineer</h3>
        </div>

        <p class="muted footer-description">
          Notas prácticas sobre Azure, automatización e infraestructura reproducible.
        </p>

        <div class="footer-stack-pill">
          Built with Astro · Markdown · GitHub Pages
        </div>
      </div>

      <div>
        <h4 class="footer-title">Navegación</h4>
        <ul class="footer-links">
          <li><a href={base}>Inicio</a></li>
          <li><a href={`${base}blog/`}>Blog</a></li>
          <li><a href={`${base}labs/`}>Labs</a></li>
          <li><a href={`${base}about/`}>Sobre mí</a></li>
        </ul>
      </div>

      <div>
        <h4 class="footer-title">Presencia</h4>
        <ul class="footer-links">
          <li>
            <a href="https://github.com/acatalan87" target="_blank" rel="noopener noreferrer">
              GitHub
            </a>
          </li>
          <li>
            <a href="https://www.linkedin.com/in/angel-luis-catal%C3%A1n-s%C3%A1nchez-35a68352/" target="_blank" rel="noopener noreferrer">
              LinkedIn
            </a>
          </li>
          <li>
            <a href="mailto:acatalan87@outlook.com">
              Contacto
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="muted">Portfolio técnico personal orientado a cloud engineering.</p>
      <p class="muted">© 2026 Ángel</p>
    </div>
  </div>
</footer>
  </body>
</html>